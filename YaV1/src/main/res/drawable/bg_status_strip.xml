<?xml version="1.0" encoding="utf-8"?>
<!-- Drive status strip: panel fill with a 1dp bottom separator line. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle"><solid android:color="@color/panel" /></shape>
    </item>
    <item android:gravity="bottom" android:height="1dp">
        <shape android:shape="rectangle"><solid android:color="@color/line" /></shape>
    </item>
</layer-list>
