<?xml version="1.0" encoding="utf-8"?>
<!-- Interactive TOOLS button: flat panel card with a band-ku ripple. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#405AC8FA">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/panel_high" />
            <corners android:radius="@dimen/radius_card" />
            <stroke android:width="1dp" android:color="@color/line" />
        </shape>
    </item>
</ripple>
