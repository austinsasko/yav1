<?xml version="1.0" encoding="utf-8"?>
<!-- TOOLS control panel, landscape: two columns of the same cards/ids as portrait. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:padding="@dimen/space_m">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginRight="@dimen/space_s">

        <!-- Savvy speed stepper -->
        <RelativeLayout
            android:id="@+id/savvy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_alert_card"
            android:padding="@dimen/alert_card_pad">
            <TextView
                android:id="@+id/savvy_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tools_savvy_label"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/ink2" />
            <ImageButton
                android:id="@+id/savvy_speed_minus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_below="@+id/savvy_label"
                android:layout_alignParentLeft="true"
                android:layout_marginTop="@dimen/space_s"
                android:background="@drawable/bg_tool_button"
                android:src="@drawable/ic_minus"
                android:onClick="clickCtrl"
                android:contentDescription="@string/cd_savvy_minus" />
            <LinearLayout
                android:id="@+id/savvy_value_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/savvy_label"
                android:layout_centerHorizontal="true"
                android:layout_alignBottom="@+id/savvy_speed_minus"
                android:layout_alignTop="@+id/savvy_speed_minus"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/savvy_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="34sp"
                    android:includeFontPadding="false"
                    android:textColor="@color/ink"
                    android:text="35" />
                <TextView
                    android:id="@+id/savvy_speed_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="@color/ink2"
                    android:text="MPH" />
            </LinearLayout>
            <ImageButton
                android:id="@+id/savvy_speed_plus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_below="@+id/savvy_label"
                android:layout_alignParentRight="true"
                android:layout_marginTop="@dimen/space_s"
                android:background="@drawable/bg_tool_button"
                android:src="@drawable/ic_plus"
                android:onClick="clickCtrl"
                android:contentDescription="@string/cd_savvy_plus" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/savvy_speed_minus"
                android:layout_marginTop="@dimen/space_s"
                android:textSize="12sp"
                android:textColor="@color/ink2"
                android:text="@string/tools_savvy_sub" />
        </RelativeLayout>

        <!-- Audio output chips -->
        <LinearLayout
            android:id="@+id/v1_audio_ctrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:orientation="vertical"
            android:background="@drawable/bg_alert_card"
            android:padding="@dimen/alert_card_pad">
            <TextView
                android:id="@+id/audio_ctrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tools_audio_label"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/ink2" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <LinearLayout
                    android:id="@+id/chip_alert"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_tool_off"
                    android:paddingTop="@dimen/space_s"
                    android:paddingBottom="@dimen/space_s">
                    <ImageButton
                        android:id="@+id/alert_sound"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/alert_off"
                        android:onClick="clickCtrl"
                        android:contentDescription="@string/cd_phone_alert" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/ink"
                        android:text="@string/tools_chip_phone" />
                    <TextView
                        android:id="@+id/alert_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:textAllCaps="true"
                        android:textSize="10sp"
                        android:letterSpacing="0.08"
                        android:textColor="@color/ink2"
                        android:text="@string/tools_state_off" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/chip_voice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="@dimen/space_s"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_tool_off"
                    android:paddingTop="@dimen/space_s"
                    android:paddingBottom="@dimen/space_s">
                    <ImageButton
                        android:id="@+id/voice_sound"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/voice_off"
                        android:onClick="clickCtrl"
                        android:contentDescription="@string/cd_voice_alert" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/ink"
                        android:text="@string/tools_chip_voice" />
                    <TextView
                        android:id="@+id/voice_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:textAllCaps="true"
                        android:textSize="10sp"
                        android:letterSpacing="0.08"
                        android:textColor="@color/ink2"
                        android:text="@string/tools_state_off" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/chip_vibrate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="@dimen/space_s"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_tool_off"
                    android:paddingTop="@dimen/space_s"
                    android:paddingBottom="@dimen/space_s">
                    <ImageButton
                        android:id="@+id/vibrate_sound"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:scaleType="fitCenter"
                        android:src="@drawable/vibrate_off"
                        android:onClick="clickCtrl"
                        android:contentDescription="@string/cd_vibrate_alert" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/ink"
                        android:text="@string/tools_chip_vibrate" />
                    <TextView
                        android:id="@+id/vibrate_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="monospace"
                        android:textAllCaps="true"
                        android:textSize="10sp"
                        android:letterSpacing="0.08"
                        android:textColor="@color/ink2"
                        android:text="@string/tools_state_off" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Lockouts row -->
        <LinearLayout
            android:id="@+id/v1_lockout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_alert_card"
            android:padding="@dimen/alert_card_pad">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/lockout_ctrl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/ink"
                    android:text="@string/tools_lockout_label" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp"
                    android:textColor="@color/ink2"
                    android:text="@string/tools_lockout_sub" />
            </LinearLayout>
            <Button
                android:id="@+id/lockout"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="64dp"
                android:minHeight="0dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:background="@drawable/bg_state_pill"
                android:fontFamily="monospace"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:letterSpacing="0.06"
                android:textColor="@color/state_locked"
                android:onClick="clickCtrl"
                android:text="@string/tool_tab_lockout_disabled" />
        </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginLeft="@dimen/space_s">

        <!-- V1 mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            
            android:orientation="vertical"
            android:background="@drawable/bg_alert_card"
            android:padding="@dimen/alert_card_pad">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tools_mode_label"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/ink2" />
            <Button
                android:id="@+id/v1_mode"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/space_s"
                android:minHeight="0dp"
                android:background="@drawable/bg_tool_button"
                android:textSize="30sp"
                android:textColor="#FF2A20"
                android:onClick="clickCtrl"
                android:text=""
                android:contentDescription="@string/tools_mode_label" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:textSize="12sp"
                android:textColor="@color/ink2"
                android:text="@string/tools_mode_sub" />
        </LinearLayout>

        <!-- Settings profile row -->
        <RelativeLayout
            android:id="@+id/v1_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:background="@drawable/bg_alert_card"
            android:padding="@dimen/alert_card_pad">
            <TextView
                android:id="@+id/setting_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tools_settings_label"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/ink2" />
            <ImageView
                android:id="@+id/setting_chevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_below="@+id/setting_title"
                android:layout_alignParentRight="true"
                android:layout_marginTop="14dp"
                android:src="@drawable/ic_chevron_right"
                android:importantForAccessibility="no" />
            <Button
                android:id="@+id/current_setting_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/setting_title"
                android:layout_toLeftOf="@+id/setting_chevron"
                android:minHeight="48dp"
                android:background="@android:color/transparent"
                android:gravity="center_vertical|left"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="@color/ink"
                android:singleLine="true"
                android:ellipsize="end"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:onClick="clickCtrl" />
        </RelativeLayout>

        <!-- Custom sweeps row -->
        <RelativeLayout
            android:id="@+id/v1_sweep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:background="@drawable/bg_alert_card"
            android:padding="@dimen/alert_card_pad">
            <TextView
                android:id="@+id/sweep_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tool_tab_sweep"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textColor="@color/ink2" />
            <ImageView
                android:id="@+id/sweep_chevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_below="@+id/sweep_title"
                android:layout_alignParentRight="true"
                android:layout_marginTop="14dp"
                android:src="@drawable/ic_chevron_right"
                android:importantForAccessibility="no" />
            <Button
                android:id="@+id/current_sweep_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/sweep_title"
                android:layout_toLeftOf="@+id/sweep_chevron"
                android:minHeight="48dp"
                android:background="@android:color/transparent"
                android:gravity="center_vertical|left"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textColor="@color/ink"
                android:singleLine="true"
                android:ellipsize="end"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:onClick="clickCtrl" />
        </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
