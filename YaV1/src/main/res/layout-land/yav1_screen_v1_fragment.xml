<?xml version="1.0" encoding="utf-8"?>
<!-- V1 replica display (landscape), framed as one instrument panel. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ground"
    android:padding="@dimen/space_m">
<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="false"
    android:focusable="false"
    android:padding="@dimen/space_l"
    android:background="@drawable/bg_alert_card">
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"
        android:id="@+id/left_part">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/bogey_cont"
            android:gravity="bottom"
            android:layout_marginTop="3dp"
            android:paddingBottom="3dp">
            <com.franckyl.yav1.ui.SegmentDisplayView
                android:layout_width="64dp"
                android:layout_height="92dp"
                android:id="@+id/bogey"
                android:layout_marginLeft="10dp"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/red_dot"
                android:id="@+id/bogey_dot"
                android:layout_gravity="bottom"
                android:layout_marginLeft="10dp"
                android:layout_toRightOf="@+id/bogey"
                android:layout_alignParentBottom="false" />
        </RelativeLayout>
        <com.franckyl.yav1.ui.DotMeterView
            android:layout_width="128dp"
            android:layout_height="20dp"
            android:id="@+id/signal"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="15dp"
            android:layout_below="@+id/bogey_cont" />
        <ListView
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:id="@+id/alertList"
            android:layout_gravity="center_horizontal"
            android:divider="@android:color/transparent"
            android:background="@android:color/transparent"
            android:layout_below="@+id/signal"
            android:layout_marginTop="30dp" />
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical|center_horizontal"
        android:layout_alignParentRight="false"
        android:longClickable="true"
        android:id="@+id/alert_container"
        android:layout_toRightOf="@+id/left_part"
        android:layout_marginTop="5dp"
        android:layout_toLeftOf="@+id/cont_band"
        android:layout_centerHorizontal="true">
        <com.franckyl.yav1.ui.DirectionArrowView
            android:layout_width="84dp"
            android:layout_height="64dp"
            android:id="@+id/front"
            android:contentDescription="@string/cd_threat_direction" />
        <com.franckyl.yav1.ui.DirectionArrowView
            android:layout_width="84dp"
            android:layout_height="44dp"
            android:id="@+id/side"
            android:layout_below="@+id/front" />
        <com.franckyl.yav1.ui.DirectionArrowView
            android:layout_width="84dp"
            android:layout_height="60dp"
            android:id="@+id/rear"
            android:layout_below="@+id/side"
            android:visibility="visible" />
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginTop="5dp"
        android:id="@+id/cont_band"
        android:layout_alignParentRight="true"
        android:layout_marginRight="10dp">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/cont_laser"
            android:layout_alignParentTop="true"
            android:gravity="center_vertical"
            android:paddingTop="3dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/red_dot"
                android:id="@+id/band_laser"
                android:layout_gravity="center_vertical"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L"
                android:layout_gravity="left"
                android:gravity="center_vertical|left"
                android:textStyle="bold"
                android:textAppearance="@android:style/TextAppearance.Medium"
                android:layout_alignParentRight="false"
                android:layout_toRightOf="@+id/band_laser"
                android:paddingLeft="5dp" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cont_ka"
            android:layout_below="@+id/cont_laser"
            android:gravity="center_vertical"
            android:paddingTop="3dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/red_dot"
                android:id="@+id/band_ka"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ka"
                android:layout_gravity="center_vertical|left"
                android:gravity="center_vertical|left"
                android:textStyle="bold"
                android:textAppearance="@android:style/TextAppearance.Medium"
                android:layout_toRightOf="@+id/band_ka"
                android:paddingLeft="5dp" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cont_k"
            android:layout_below="@+id/cont_ka"
            android:gravity="center_vertical"
            android:paddingTop="3dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/red_dot"
                android:id="@+id/band_k"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="K"
                android:layout_gravity="center_vertical|left"
                android:gravity="center_vertical|left"
                android:textStyle="bold"
                android:textAppearance="@android:style/TextAppearance.Medium"
                android:layout_toRightOf="@+id/band_k"
                android:paddingLeft="5dp" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cont_x"
            android:layout_below="@+id/cont_k"
            android:gravity="center_vertical"
            android:paddingTop="3dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/red_dot"
                android:id="@+id/band_x"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X"
                android:layout_gravity="center_vertical|left"
                android:gravity="center_vertical|left"
                android:textStyle="bold"
                android:textAppearance="@android:style/TextAppearance.Medium"
                android:layout_toRightOf="@+id/band_x"
                android:paddingLeft="5dp" />
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
</FrameLayout>
