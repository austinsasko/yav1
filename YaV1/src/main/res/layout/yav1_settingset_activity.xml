<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/ground">
    <ListView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@android:id/list"
            android:choiceMode="singleChoice"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:paddingTop="@dimen/space_s"
            android:clipToPadding="false"
            android:longClickable="false"
        android:layout_alignParentTop="true"
        android:layout_above="@+id/bar" />
    <LinearLayout
        android:layout_width="match_parent"
        android:id="@+id/bar"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_m"
        android:layout_alignParentBottom="true">
        <Button
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:minHeight="0dp"
            android:background="@drawable/bg_tool_button"
            android:textColor="@color/ink"
            android:textAllCaps="false"
            android:text="@string/gen_export"
            android:id="@+id/backup"
            android:layout_weight="1"
            android:onClick="onClick" />
        <Button
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:minHeight="0dp"
            android:layout_marginLeft="@dimen/space_s"
            android:background="@drawable/bg_tool_button"
            android:textColor="@color/ink"
            android:textAllCaps="false"
            android:text="@string/gen_import"
            android:id="@+id/restore"
            android:layout_weight="1"
            android:onClick="onClick" />
    </LinearLayout>
</RelativeLayout>
