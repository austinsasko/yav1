<?xml version="1.0" encoding="utf-8"?>
<preference-headers
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== Detector ===== -->
    <header android:title="@string/settings_cat_detector" />

    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
            android:icon="@drawable/ic_hdr_general"
            android:title="@string/pref_h_general"
            android:summary="@string/pref_h_general_summary">
        <extra android:name="settings" android:value="general"/>
    </header>
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
            android:icon="@drawable/ic_hdr_display"
            android:title="@string/pref_h_display"
            android:summary="@string/pref_h_display_summary">
        <extra android:name="settings" android:value="display"/>
    </header>
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
        android:icon="@drawable/ic_hdr_sound"
            android:title="@string/pref_h_sound"
        android:summary="@string/pref_h_sound_summary">
        <extra android:name="settings" android:value="sound"/>
    </header>

    <!-- ===== Quiet ride ===== -->
    <header android:title="@string/settings_cat_quiet" />

    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
            android:icon="@drawable/ic_hdr_lock"
            android:title="@string/pref_h_lockout"
            android:summary="@string/pref_h_lockout_summary">
        <extra android:name="settings" android:value="lockout"/>
    </header>
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
            android:icon="@drawable/ic_hdr_box"
            android:title="@string/pref_h_boxes"
            android:summary="@string/pref_h_boxes_summary">
        <extra android:name="settings" android:value="box"/>
    </header>

    <!-- ===== Awareness ===== -->
    <header android:title="@string/settings_cat_awareness" />

    <!-- [P2-POI] -->
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
        android:icon="@drawable/ic_hdr_camera"
            android:title="@string/pref_h_poi"
        android:summary="@string/pref_h_poi_summary">
        <extra android:name="settings" android:value="poi"/>
    </header>
    <!-- [P2-ADSB] -->
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
        android:icon="@drawable/ic_hdr_plane"
            android:title="@string/pref_h_aircraft"
        android:summary="@string/pref_h_aircraft_summary">
        <extra android:name="settings" android:value="aircraft"/>
    </header>
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
        android:icon="@drawable/ic_hdr_map"
            android:title="@string/pref_h_g_map"
        android:summary="@string/pref_h_g_map_summary">
        <extra android:name="settings" android:value="gmap"/>
    </header>
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
            android:icon="@drawable/ic_hdr_log"
            android:title="@string/pref_h_logging"
            android:summary="@string/pref_h_logging_summary">
        <extra android:name="settings" android:value="record"/>
    </header>

    <!-- ===== Automation ===== -->
    <header android:title="@string/settings_cat_automation" />

    <!-- [P3-GEO] location based automatic V1 profile switching -->
    <header android:fragment="com.glasslsoftware.yav1.YaV1PrefFragment"
        android:icon="@drawable/ic_hdr_pin"
            android:title="@string/pref_h_geo"
        android:summary="@string/pref_h_geo_summary">
        <extra android:name="settings" android:value="geo"/>
    </header>
</preference-headers>
